# Only needed for deployment (e.g. Vercel). Without these, the app falls
# back to writing to a local JSON file in /tmp, which works fine for
# `npm run dev` but won't persist across serverless invocations in prod.
#
# Get these free at https://upstash.com — create a Redis database,
# then copy the REST URL and token from its dashboard.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
